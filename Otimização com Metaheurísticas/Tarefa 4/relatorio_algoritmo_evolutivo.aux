\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Comparação de convergência entre nossa implementação DE/Best/1/bin, PyMoo DE/Rand/1/bin e o GA implementado. Nossa estratégia alcança os menores valores finais, o PyMoo converge melhor no início e o GA permanece em patamar superior ao longo de toda a execução.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:convergencia_pymoo}{{4}{9}{Comparação de convergência entre nossa implementação DE/Best/1/bin, PyMoo DE/Rand/1/bin e o GA implementado. Nossa estratégia alcança os menores valores finais, o PyMoo converge melhor no início e o GA permanece em patamar superior ao longo de toda a execução}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Distribuição de valores finais comparando nossa DE/Best/1/bin, PyMoo DE/Rand/1/bin e o GA implementado. A estratégia DE/Best/1/bin apresenta a menor mediana e a menor dispersão; o PyMoo ocupa posição intermediária; e o GA apresenta a maior dispersão e os piores valores finais.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:boxplot_pymoo}{{5}{10}{Distribuição de valores finais comparando nossa DE/Best/1/bin, PyMoo DE/Rand/1/bin e o GA implementado. A estratégia DE/Best/1/bin apresenta a menor mediana e a menor dispersão; o PyMoo ocupa posição intermediária; e o GA apresenta a maior dispersão e os piores valores finais}{figure.5}{}}
